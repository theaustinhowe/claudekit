{
  "name": "@devkit/ui",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "typesVersions": {
    "*": {
      "components/*": [
        "src/components/*.tsx"
      ]
    }
  },
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "storybook": "storybook dev -p 6006 --no-open",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react-day-picker": "^9.0.0",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "shiki": "^3.22.0",
    "tailwind-merge": "^3.4.0"
  },
  "peerDependencies": {
    "@devkit/hooks": "workspace:*",
    "next-themes": "^0.4.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "sonner": "^2.0.0"
  },
  "peerDependenciesMeta": {
    "@devkit/hooks": {
      "optional": true
    },
    "next-themes": {
      "optional": true
    },
    "sonner": {
      "optional": true
    }
  },
  "devDependencies": {
    "vitest": "^4.0.18",
    "@storybook/addon-themes": "^10.2.8",
    "@storybook/react": "^10.2.8",
    "@storybook/react-vite": "^10.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "storybook": "^10.2.8",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3"
  }
}
