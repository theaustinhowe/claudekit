{
  "name": "@claudekit/claude-usage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./components/*": "./src/components/*.tsx",
    "./components/usage-section": "./src/components/usage-section.tsx"
  },
  "typesVersions": {
    "*": {
      "server": [
        "src/server.ts"
      ],
      "components/*": [
        "src/components/*.tsx"
      ],
      "components/usage-section": [
        "src/components/usage-section.tsx"
      ]
    }
  },
  "scripts": {
    "dev": "tsc --noEmit --watch",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run"
  },
  "dependencies": {
    "lucide-react": "^0.563.0"
  },
  "peerDependencies": {
    "@claudekit/hooks": "workspace:*",
    "@claudekit/ui": "workspace:*",
    "react": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "@claudekit/hooks": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
