{
  "name": "@devkit/claude-usage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./server": "./src/server.ts",
    "./components/*": "./src/components/*.tsx"
  },
  "typesVersions": {
    "*": {
