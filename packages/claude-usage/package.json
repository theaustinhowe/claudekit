      ]
    }
  },
  "scripts": {
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "lucide-react": "^0.468.0"
  },
  "peerDependencies": {
    "@devkit/ui": "workspace:*",
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
