# Shared environment variables for all devkit apps.
# Copy to .env.local and fill in values.
# App-specific .env.local files override these values.

# GitHub Personal Access Token (used by Gadget + GoGo Orchestrator)
# @url https://github.com/settings/tokens
# @hint Needs "repo" scope. Classic token recommended.
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Log level for all apps (default: info)
# @hint Options: trace, debug, info, warn, error, fatal
# LOG_LEVEL=info

# Override database path (each app has its own default)
# DATABASE_PATH=
