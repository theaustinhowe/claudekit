# Shared environment variables for all devkit apps.
# Copy to .env.local and fill in values.
# App-specific .env.local files override these values.

# GitHub Personal Access Token (used by Gadget + GoGo)
# GITHUB_TOKEN=

# Anthropic API Key (used by Gadget generator + GoGo agent runner)
# ANTHROPIC_API_KEY=

# OpenAI API Key (optional, used by Gadget + GoGo Codex agent)
# OPENAI_API_KEY=

# Log level for all apps (default: info)
# LOG_LEVEL=info

# Database path (all apps use DATABASE_PATH, each has its own default)
# B4U:               data/b4u.duckdb
# Gadget:            ~/.gadget/data.duckdb
# GoGo Orchestrator: ./data/gogo.duckdb
# DATABASE_PATH=
