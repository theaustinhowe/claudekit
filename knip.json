{
  "$schema": "https://unpkg.com/knip@5/schema.json",
  "exclude": ["optionalPeerDependencies"],
  "workspaces": {
    ".": {
      "entry": ["scripts/*.ts"]
    },
    "apps/web": {},
    "apps/gadget": {},
    "apps/gogo-web": {},
    "apps/gogo-orchestrator": {
      "ignore": ["src/**/*.test.ts"]
    },
    "apps/inside": {
      "ignoreDependencies": ["@claudekit/playwright"]
    },
    "apps/b4u": {},
    "packages/ui": {
      "entry": ["src/components/*.tsx"],
      "ignore": ["src/components/*.stories.tsx", ".storybook/**"]
    },
    "packages/duckdb": {},
    "packages/hooks": {},
    "packages/session": {},
    "packages/claude-runner": {},
    "packages/logger": {
      "ignoreDependencies": ["pino-pretty"]
    },
    "packages/gogo-shared": {},
    "packages/claude-usage": {
      "entry": ["src/components/*.tsx"]
    },
    "packages/mcp-logs": {}
  }
}
