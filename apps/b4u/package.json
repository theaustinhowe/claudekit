    "@duckdb/node-api": "1.4.4-r.1",
    "lucide-react": "^0.475.0",
    "motion": "^12.6.0",
    "next": "16.1.6",
    "next-themes": "^0.4.6",
    "playwright": "^1.58.2",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.19.33",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@tailwindcss/postcss": "^4.1.18",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
