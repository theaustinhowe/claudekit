# Orchestrator REST API URL (auto-detects from hostname if not set)
# @hint Only set this if running on a non-standard host
# NEXT_PUBLIC_API_URL=http://localhost:2201

# Orchestrator WebSocket URL (auto-detects from hostname if not set)
# NEXT_PUBLIC_WS_URL=ws://localhost:2201/ws

# Orchestrator port for URL auto-detection (default: 2201)
# NEXT_PUBLIC_ORCHESTRATOR_PORT=2201

# Default work directory for agent worktrees (default: /tmp/agent-worktrees)
# NEXT_PUBLIC_DEFAULT_DIRECTORY=/tmp/agent-worktrees
