# MCP API Token for programmatic access
# @hint Any random string — used as Bearer token for MCP API auth
MCP_API_TOKEN=your-secret-token-here

# Database path override (default: ~/.gadget/data.duckdb)
# DB_PATH=/custom/path/to/data.duckdb

# GitHub Personal Access Token for GitHub API integration
# @url https://github.com/settings/tokens
# GITHUB_PERSONAL_ACCESS_TOKEN=

# Brave Search API key for web search
# @url https://brave.com/search/api/
# BRAVE_API_KEY=

# Firecrawl API key for web scraping and crawling
# @url https://firecrawl.dev
# FIRECRAWL_API_KEY=

# Exa AI search API key
# @url https://dashboard.exa.ai/api-keys
# EXA_API_KEY=

# Tavily AI search API key
# @url https://app.tavily.com/home
# TAVILY_API_KEY=

# Notion API integration token
# @url https://developers.notion.com
# @hint Create an internal integration at notion.so/my-integrations
# NOTION_API_KEY=

# Google Maps API key
# @url https://console.cloud.google.com/apis/credentials
# GOOGLE_MAPS_API_KEY=

# Resend email API key
# @url https://resend.com/api-keys
# RESEND_API_KEY=

# Axiom observability API token
# @url https://app.axiom.co/settings/api-tokens
# AXIOM_API_TOKEN=

# Raygun error tracking API key
# @url https://app.raygun.com
# RAYGUN_API_KEY=

# Stripe payments API key
# @url https://dashboard.stripe.com/apikeys
# @hint Use test mode key (sk_test_...) for development
# STRIPE_API_KEY=

# Replicate AI model API token
# @url https://replicate.com/account/api-tokens
# REPLICATE_API_TOKEN=

# GitLab personal access token
# @url https://gitlab.com/-/user_settings/personal_access_tokens
# GITLAB_TOKEN=

# Slack Bot OAuth token
# @url https://api.slack.com/apps
# @hint Format: xoxb-... (needs channels:read, chat:write scopes)
# SLACK_BOT_TOKEN=

# Slack workspace/team ID
# @hint Find in workspace settings or URL (e.g., T01ABCDEF)
# SLACK_TEAM_ID=

# Sentry error monitoring auth token
# @url https://sentry.io/settings/auth-tokens/
# SENTRY_AUTH_TOKEN=

# Linear project management API key
# @url https://linear.app/settings/api
# LINEAR_API_KEY=

# Supabase management API access token
# @url https://supabase.com/dashboard/account/tokens
# SUPABASE_ACCESS_TOKEN=
