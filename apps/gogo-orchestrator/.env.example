# DuckDB database path (default: ./data/gogo.duckdb)
# DATABASE_PATH=./data/gogo.duckdb

# GitHub Personal Access Token for issue polling and PR creation
# @url https://github.com/settings/tokens/new?scopes=repo,workflow&description=ClaudeKit
# @hint Needs "repo" scope. Classic token recommended.
GITHUB_PERSONAL_ACCESS_TOKEN=your-github-token-here

# HTTP server port (default: 2201)
# PORT=2201

# CORS allowed origins, comma-separated
# @hint Default: http://localhost:2200,http://127.0.0.1:2100
# ALLOWED_ORIGINS=http://localhost:2200,http://127.0.0.1:2100
