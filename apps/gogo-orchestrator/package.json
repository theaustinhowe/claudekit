{
  "name": "gogo-orchestrator",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:seed": "tsx src/db/seed.ts",
    "db:migrate": "tsx src/db/migrate.ts",
    "db:reset": "rm -f data/gogo.duckdb data/gogo.duckdb.wal"
  },
  "dependencies": {
    "@claudekit/claude-runner": "workspace:*",
    "@claudekit/duckdb": "workspace:*",
    "@claudekit/github": "workspace:*",
    "@claudekit/gogo-shared": "workspace:*",
    "@claudekit/logger": "workspace:*",
    "@claudekit/session": "workspace:*",
    "@duckdb/node-api": "1.4.4-r.1",
    "@fastify/cors": "^10.0.0",
    "@fastify/websocket": "^11.0.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.2.0",
    "octokit": "^4.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
